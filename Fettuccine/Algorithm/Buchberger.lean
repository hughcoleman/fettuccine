import Fettuccine.Algorithm.Division

/-!
# Buchberger's Algorithm

This file implements an "untrusted" version of Buchberger's algorithm for computing Gröbner bases of
ideals of polynomial rings. It produces a small witness permitting efficient verification of the
basis.

## Definitions

* `sPolynomial ord f g` : the S-polynomial of `f` and `g` with respect to the monomial order `ord`.
* `untrustedBuchberger ord I (fuel)` : computes a Gröbner basis for the ideal generated by `I` with
  respect to the monomial order `ord`, constrained by `fuel` (default: 2048).
-/

namespace FMvPolynomial

variable {n : ℕ}
variable {R : Type*} [DecidableEq R] [Zero R] [AddGroup R] [DivisionRing R]

/-- The **S-polynomial** of two (non-zero) polynomials `f` and `g` with respect to the monomial
    order `ord`. -/
-- S(f, g) = (l / lm_f) * lc_g * f - (l / lm_g) * lc_f * g
--         = lcm(lm_f, lm_g) / lm_f * lc_g * f - lcm(lm_f, lm_g) / lm_g * lc_f * g
def sPolynomial (ord : FMonomialOrder n) (f g : FMvPolynomial n R) : FMvPolynomial n R :=
  match f.leadingTerm ord, g.leadingTerm ord with
  | some (lm_f, lc_f), some (lm_g, lc_g) =>
    -- These divisions necessarily always succeed because the lowest common multiple is
    -- definitionally divisible by both.
    let lcm := FMonomial.lcm lm_f lm_g
    let mf  := (lcm.divide lm_f).getD (FMonomial.zero n)
    let mg  := (lcm.divide lm_g).getD (FMonomial.zero n)
    sub (mulMonomial mf lc_g f) (mulMonomial mg lc_f g)
  | _, _ =>
    -- If either polynomial is zero, the S-polynomial is conventionally taken to be zero. (This
    -- generally doesn't come up in practice.)
    FMvPolynomial.zero

section Buchberger

-- A vector of coefficients, implicitly indexed by the original generators.
abbrev CoefficientVector (n' : ℕ) (n : ℕ) (R : Type*) :=
  Vector (FMvPolynomial n R) n'

namespace CoefficientVector

def zero (n' n : ℕ) : CoefficientVector n' n R :=
  Vector.replicate n' (FMvPolynomial.zero)

def add {n' n : ℕ} (a b : CoefficientVector n' n R) : CoefficientVector n' n R :=
  ⟨Array.zipWith FMvPolynomial.add a.toArray b.toArray, by simp [a.size_toArray, b.size_toArray]⟩

def sub {n' n : ℕ} (a b : CoefficientVector n' n R) : CoefficientVector n' n R :=
  ⟨Array.zipWith FMvPolynomial.sub a.toArray b.toArray, by simp [a.size_toArray, b.size_toArray]⟩

/-- Scale a vector by a monomial. -/
def mulMonomial {n' n : ℕ} (m : FMonomial n) (c : R) (v : CoefficientVector n' n R) :
    CoefficientVector n' n R :=
  ⟨v.toArray.map (FMvPolynomial.mulMonomial m c), by simp [v.size_toArray]⟩

/-- Scale a vector by a polynomial. -/
def mul {n' n : ℕ} (f : FMvPolynomial n R) (v : CoefficientVector n' n R) :
    CoefficientVector n' n R :=
  ⟨v.toArray.map (FMvPolynomial.mul f), by simp [v.size_toArray]⟩

/-- Compute the linear combination. -/
def linearCombinationOf {n' n : ℕ}
    (as : Array (FMvPolynomial n R)) (bs : Array (CoefficientVector n' n R)) :
    CoefficientVector n' n R :=
  (Array.zip as bs).foldl (init := zero n' n)
    fun acc (a, b) => acc.add (b.mul a)

end CoefficientVector

-- Not everything needs this, but does implicitly depend on it.
variable (ord : FMonomialOrder n)

/-- The information required to witness a Gröbner basis. -/
structure Witness (n : ℕ) (R : Type*) where
  i : Array (Array (FMvPolynomial n R))
  j : Array (Array (Array (FMvPolynomial n R)))

/-- A proposed Gröbner basis, alongside computational witnesses that can be used to certify the
    computation. -/
structure CandidateGroebnerBasis (n : ℕ) (R : Type*) where
  G : Array (FMvPolynomial n R)
  -- The witnesses provide the information needed to prove that `G ⊆ ⟨I⟩` and that `S(f, g) → 0`
  -- for each `f, g ∈ G`.
  witness : Witness n R

private abbrev AugmentedBasis (n' n : ℕ) (R : Type*) :=
  Array (FMvPolynomial n R × CoefficientVector n' n R)

/-- Extract the basis elements from an augmented basis. -/
def AugmentedBasis.basis {n' n : ℕ} (augmentedBasis : AugmentedBasis n' n R) :
    Array (FMvPolynomial n R) :=
  augmentedBasis.map Prod.fst

/-- Extract the coefficient vectors from an augmented basis. -/
def AugmentedBasis.basisCoefficients {n' n : ℕ} (augmentedBasis : AugmentedBasis n' n R) :
    Array (CoefficientVector n' n R) :=
  augmentedBasis.map Prod.snd

/-- **Buchberger's algorithm** for computing a Gröbner basis. -/
def untrustedBuchberger' (I : Array (FMvPolynomial n R))
    -- As with `untrustedMvDivide`, this should be more than enough fuel for any practical example.
    (fuel : ℕ := 4096) : CandidateGroebnerBasis n R :=
  -- The key is to keep track of expressions of each (added) basis element as a linear combination
  -- of the initial set of generators.
  let initialAugmentedBasis : AugmentedBasis I.size n R := (
    -- Initially, we take all given generators with their corresponding unit vectors. We'll drop
    -- any zeroes.
    I.mapIdx (fun i g =>
      let g' := normalize g
      if g'.size > 0 then
        let eᵢ : Vector (FMvPolynomial n R) I.size :=
          Vector.ofFn fun i' =>
            if i == i' then
              1
            else
              0
        some (g', ⟨eᵢ.toArray, by simp [eᵢ.size_toArray]⟩)
      else
        none
    ) |>.filterMap id
  )
  let initialQueue : List (ℕ × ℕ) :=
    (List.range initialAugmentedBasis.size)
      |>.flatMap fun i₀ => (List.range i₀).map (·, i₀)
  let augmentedBasis := loop fuel initialAugmentedBasis initialQueue
  -- Construct a witness by recording the required coefficient vectors.
  let basis             := augmentedBasis.basis
  let basisCoefficients := augmentedBasis.basisCoefficients
  ⟨basis, ⟨
    basisCoefficients.map (·.toArray),
    -- We'll just make a gigantic, two-dimensional lookup table of each S-polynomial. (This is
    -- redundant by about a factor of two; whatever...)
    basis.map fun f =>
      basis.map fun g =>
        let ⟨quotients, r⟩ := untrustedMvDivide ord (sPolynomial ord f g) basis
        quotients⟩⟩
where
  /-- Consume one pair `(i, j)` and return the updated basis/coefficients and remaining queue. -/
  loopOne
      (augmentedBasis : AugmentedBasis I.size n R)
      (queue : List (ℕ × ℕ))
      (i j : ℕ) : AugmentedBasis I.size n R × List (ℕ × ℕ) :=
    match augmentedBasis[i]?, augmentedBasis[j]? with
    | some (f, vf), some (g, vg) =>
      -- Extract the leading monomials of `f` and `g`, which we expect exist because we've filtered
      -- zeroes out of the basis.
      match f.leadingTerm ord, g.leadingTerm ord with
      | some (lm_f, lc_f), some (lm_g, lc_g) =>
        if lm_f.isRelativelyPrime lm_g then
          -- If the leading monomials are relatively prime, then the S-polynomial is guaranteed to
          -- reduce to zero (regardless of the choice of monomial order), due to a theorem of
          -- Buchberger. So, in this case, we can immediately move on.
          (augmentedBasis, queue)
        else
          -- Reduce the S-polynomial of `f` and `g` modulo the basis.
          let (qs, r) := untrustedMvDivide ord (sPolynomial ord f g) augmentedBasis.basis
          if r.size == 0 then
            (augmentedBasis, queue)
          else
            -- The coefficient representation of the S-polynomial of `f` and `g` can be computed
            -- as in `sPolynomial`.
            let lcm := FMonomial.lcm lm_f lm_g
            let mf  := (lcm.divide lm_f).getD (FMonomial.zero n)
            let mg  := (lcm.divide lm_g).getD (FMonomial.zero n)
            let vs  := (vf.mulMonomial mf lc_g).sub (vg.mulMonomial mg lc_f)
            -- We can then subtract off the quotients of the reduction in order to find the
            -- coefficient representation of the remainder.
            let vq  := CoefficientVector.linearCombinationOf qs augmentedBasis.basisCoefficients
            let vr  := vs.sub vq
            -- Every additional S-polynomial introduced as a result of this must also be checked.
            let i' := augmentedBasis.size
            (augmentedBasis.push (r, vr), queue.append <| (List.range i').map (·, i'))
    -- Realistically, neither of these fallback cases should ever be reached.
      | _, _ => (augmentedBasis, queue)
    | _, _ => (augmentedBasis, queue)
  /-- Iterate through the queue until fuel is exhausted or the queue is empty. -/
  loop (fuel : ℕ)
      (augmentedBasis : AugmentedBasis I.size n R)
      (queue : List (ℕ × ℕ)) : AugmentedBasis I.size n R :=
    match fuel with
    | 0     => augmentedBasis -- this one's bad to reach
    | n + 1 =>
      match queue with
      | []               => augmentedBasis -- this is the good termination case
      | (i, j) :: queue' =>
        let (augmentedBasis₁, queue₁) := loopOne augmentedBasis queue' i j
        loop n augmentedBasis₁ queue₁

section Examples

private abbrev S := FMvPolynomial 3 ℚ

-- A small helper for generating monomials.
private def m (a b c : ℕ) : FMonomial 3 :=
  { data := #[a, b, c], hsize := by simp }

private def f₁ : S := #[(m 1 1 0, 1), (m 0 0 0, -1)] -- xy - 1
private def f₂ : S := #[(m 2 0 0, 1), (m 0 1 0, -1)] -- x² - y
private def gb : CandidateGroebnerBasis 3 ℚ :=
  untrustedBuchberger' FMonomialOrder.lex #[f₁, f₂]
#eval gb.G

private def g₁ : S := #[(m 1 1 0, 1), (m 0 0 1, -1)] -- xy - z
private def g₂ : S := #[(m 1 0 1, 1), (m 0 1 0, -1)] -- xz - y
private def g₃ : S := #[(m 0 1 1, 1), (m 1 0 0, -1)] -- yz - x
private def gb' : CandidateGroebnerBasis 3 ℚ :=
  untrustedBuchberger' FMonomialOrder.grevlex #[g₁, g₂, g₃]
#eval gb'.G

end Examples

end Buchberger

end FMvPolynomial
